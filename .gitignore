# ============================================
# ArquiControl — .gitignore
# ============================================

# --- IDE y editores ---
.idea/
.vscode/
*.swp

# --- Variables de entorno (¡nunca subir claves reales!) ---
*.env
*.env.*
!*.env.example

# --- Python / backend ---
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
.venv/
env/
.pytest_cache/
.mypy_cache/

# --- Node / frontend ---
node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz
coverage/
build/
dist/

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# --- Sistema operativo ---
.DS_Store
Thumbs.db
*.pem

# --- Archivos subidos por usuarios (deben quedar fuera del repo) ---
uploads/*
!uploads/.gitkeep

# --- Archivos temporales ---
*.tmp
*.bak
dump.rdb
