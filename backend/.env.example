# ============================================
# Configuración del backend de ArquiControl
# ============================================
# Copia este archivo como `.env` y completa los valores.
# NUNCA subas el archivo `.env` real al repositorio.

# --- MongoDB Atlas ---
# Pega aquí la cadena de conexión que Atlas te entrega en "Connect your application".
# Ejemplo: mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=mongodb+srv://USUARIO:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority

# Nombre de la base de datos que usará ArquiControl dentro del cluster.
DB_NAME=arquicontrol

# --- CORS ---
# Orígenes permitidos para que el frontend pueda consumir la API. Separa con comas si hay varios.
CORS_ORIGINS=http://localhost:3000

# --- Seguridad / JWT ---
# Cadena secreta para firmar los tokens JWT. Cámbiala por una cadena aleatoria larga.
# En Windows PowerShell puedes generarla con:
#   [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(48))
JWT_SECRET_KEY=cambia-esta-clave-por-una-cadena-aleatoria-larga

# --- Carpeta de uploads ---
# Ruta absoluta o relativa donde se guardarán los archivos subidos por los usuarios.
UPLOADS_DIR=./uploads
