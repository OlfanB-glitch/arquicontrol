# ============================================
# Configuración del frontend de ArquiControl
# ============================================
# Copia este archivo como `.env` y completa los valores.
# NUNCA subas el archivo `.env` real al repositorio.

# URL base del backend (FastAPI). Al hacer `yarn start` el backend corre en el puerto 8001.
REACT_APP_BACKEND_URL=http://localhost:8001
